{
  "name": "aoe2-control-lua",
  "displayName": "aoe2-control-lua",
  "description": "Coding support for the Age of Empires 2 Lua engine \"CONTROL\"",
  "version": "0.7.101",
  "publisher": "BigJohn",
  "repository": "https://github.com/aoe2control/aoe2-control-lua-vscode-extension",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:lua",
    "workspaceContains:**/*.lua"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aoe2-control-lua.helloWorld",
        "title": "Hello World"
      }
    ],
    "snippets": [
      {
        "language": "lua",
        "path": "./snippets/control-lua.code-snippets"
      }
    ],
    "configuration": {
      "title": "AoE2 CONTROL Lua",
      "properties": {
        "aoe2ControlLua.autoInjectLibrary": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add CONTROL API definitions to Lua workspace library for IntelliSense (requires Lua Language Server)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package": "vsce package",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
